{
  "env": {
    "ENABLE_TOOL_SEARCH": "true"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Read(~/.claude)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git tag:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(sed:*)",
      "Bash(cat:*)",
      "Task",
      "Glob",
      "Grep",
      "LS",
      "Read",
      "WebFetch",
      "WebSearch",
      "mcp__ide__getDiagnostics",
      "Bash(python3:*)",
      "Bash(python3 -c \":*)",
      "Bash(node --version:*)",
      "Bash(npm --version:*)",
      "WebFetch(domain:localhost)",
      "Bash(lsof:*)",
      "Bash(curl:*)",
      "Bash(perl:*)",
      "Bash(code:*)",
      "Bash(osascript:*)",
      "Bash(xargs:*)",
      "Bash(npx playwright *)",
      "Bash(npm test:*)",
      "Bash(git show-ref:*)",
      "Read(/private/tmp/**)",
      "mcp__playwright__browser_close",
      "mcp__playwright__browser_resize",
      "mcp__playwright__browser_console_messages",
      "mcp__playwright__browser_handle_dialog",
      "mcp__playwright__browser_evaluate",
      "mcp__playwright__browser_file_upload",
      "mcp__playwright__browser_fill_form",
      "mcp__playwright__browser_install",
      "mcp__playwright__browser_press_key",
      "mcp__playwright__browser_type",
      "mcp__playwright__browser_navigate",
      "mcp__playwright__browser_navigate_back",
      "mcp__playwright__browser_network_requests",
      "mcp__playwright__browser_take_screenshot",
      "mcp__playwright__browser_snapshot",
      "mcp__playwright__browser_click",
      "mcp__playwright__browser_drag",
      "mcp__playwright__browser_hover",
      "mcp__playwright__browser_select_option",
      "mcp__playwright__browser_tabs",
      "mcp__playwright__browser_wait_for",
      "Bash(wc -l ~/.claude/rules/**/*.md)",
      "WebFetch(domain:api.github.com)",
      "mcp__claude_ai_Slack__slack_read_thread",
      "Bash(md5 *)",
      "Bash(claude mcp *)",
      "mcp__claude_ai_Slack__slack_search_public_and_private",
      "mcp__claude_ai_Slack__slack_read_channel",
      "Bash(/Users/viniciusnyp/.claude/plugins/cache/claude-plugins-official/ralph-loop/*/scripts/setup-ralph-loop.sh:*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./.env.local)",
      "Read(./secrets/**)",
      "Read(./*.pem)",
      "Read(./*.key)",
      "Read(~/.aws/credentials)",
      "Read(~/.aws/**)",
      "Read(~/.ssh/**)"
    ],
    "ask": [],
    "defaultMode": "plan"
  },
  "model": "opus[1m]",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"/Users/viniciusnyp/.claude/scripts/hooks/post-edit-format.js\"",
            "timeout": 15,
            "async": true
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "node \"/Users/viniciusnyp/.claude/scripts/hooks/ask-question-notify.js\""
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/viniciusnyp/.claude/hooks/rtk-rewrite.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "node \"/Users/viniciusnyp/.claude/scripts/hooks/notification-event.js\""
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/scripts/context-bar.sh"
  },
  "enabledPlugins": {
    "code-review@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "dev-browser@dev-browser-marketplace": false,
    "ralph-loop@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "explanatory-output-style@claude-plugins-official": true,
    "hookify@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "claude-code-wakatime@wakatime": true,
    "github@claude-plugins-official": true,
    "slack@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "wakatime": {
      "source": {
        "source": "git",
        "url": "https://github.com/wakatime/claude-code-wakatime.git"
      }
    }
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "autoUpdatesChannel": "latest",
  "tui": "default",
  "voice": {
    "enabled": false,
    "mode": "hold"
  },
  "autoCompactEnabled": false,
  "skipAutoPermissionPrompt": true
}
